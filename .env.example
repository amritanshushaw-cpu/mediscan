# ── Required ──────────────────────────────────────────────────────────────────
# Free Groq API key — get it at https://console.groq.com (no credit card)
GROQ_API_KEY=gsk_...

# ── Optional: Bhashini (for official Indian language translation) ──────────────
# Register at https://bhashini.gov.in/ulca/user/register
# Without this, translation falls back to Groq LLM (still works great)
BHASHINI_API_KEY=your_bhashini_key
BHASHINI_USER_ID=your_bhashini_user_id

# ── Optional ──────────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=15
